{
  "name": "opencluely",
  "version": "0.1.0",
  "description": "Open-source AI overlay — three separate inputs (screen, mic, system audio) into an LLM. A Cluely-style copilot for meetings and coding problems.",
  "license": "GPL-3.0-or-later",
  "author": "Rahul Shyam",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac zip --win"
  },
  "build": {
    "appId": "com.opencluely.overlay",
    "productName": "OpenCluely",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*"
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "cue transcribes your microphone so it can help you in conversations.",
        "NSCameraUsageDescription": "cue does not use the camera.",
        "NSAudioCaptureUsageDescription": "cue captures system audio to transcribe the other participant in a call."
      }
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    }
  },
  "keywords": [
    "electron",
    "overlay",
    "ai",
    "assistant",
    "screencapturekit",
    "macos",
    "windows"
  ],
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/genai": "^0.3.0",
    "lucide-static": "^0.468.0",
    "openai": "^4.73.0"
  }
}
